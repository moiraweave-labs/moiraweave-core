# MoiraWeave AI workload platform — root docker-compose environment
# Copy to .env and fill in real values. Never commit .env.
#
# Usage:
#   cp .env.example .env

# ── api-gateway ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-before-any-real-use
# Local demo auth. Roles: admin, operator, viewer.
# DEMO_USERNAME=admin
# DEMO_PASSWORD=demo-password
# DEMO_ROLE=admin
# Optional automation credentials, comma-separated key:subject:role entries.
# MOIRA_API_KEYS=local-dev-key:local-automation:operator

# ── Optional port overrides ───────────────────────────────────────────────────
# API_GATEWAY_PORT=8000
# MOIRAWEAVE_UI_PORT=3000
# REDIS_PORT=6379
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# JAEGER_UI_PORT=16686

# ── Control plane storage ─────────────────────────────────────────────────────
# POSTGRES_DB=moiraweave
# POSTGRES_USER=moiraweave
# POSTGRES_PASSWORD=moiraweave-dev

# ── MLOps profile ─────────────────────────────────────────────────────────────
# MLFLOW_PORT=5001

# ── Models profile ────────────────────────────────────────────────────────────
# WHISPER_MODEL=tiny    # tiny | base | small | medium
# WHISPER_PORT=9000
# OLLAMA_PORT=11434

# ── worker ───────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379/0
# POSTGRES_DSN=postgresql://moiraweave:moiraweave-dev@postgres:5432/moiraweave
# WORKLOADS_DIR=/workspace/workloads
# ARTIFACTS_DIR=/workspace/artifacts
# QDRANT_URL=http://qdrant:6333
# MLFLOW_TRACKING_URI=http://mlflow:80
# MLFLOW_MODEL_NAME=moiraweave-whisper
# MLFLOW_EXPERIMENT_NAME=moiraweave-inference

# ── drift-detector (DRIFT_ prefix required) ──────────────────────────────────
# DRIFT_QDRANT_URL=http://qdrant:6333
# DRIFT_QDRANT_COLLECTION=transcriptions
# DRIFT_QDRANT_SAMPLE_SIZE=500
# DRIFT_QDRANT_REFERENCE_SIZE=500
# DRIFT_PUSHGATEWAY_URL=http://prometheus-pushgateway.monitoring.svc.cluster.local:9091
# DRIFT_DRIFT_THRESHOLD=0.5
