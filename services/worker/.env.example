# MoiraWeave worker environment variables
# Copy to .env and adjust as needed.

REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://moiraweave:moiraweave-dev@postgres:5432/moiraweave
LOG_LEVEL=INFO
WORKLOADS_DIR=/workspace/workloads
ARTIFACTS_DIR=/workspace/artifacts
RUN_TTL_SECONDS=604800
HEARTBEAT_INTERVAL_SECONDS=10
STALE_RUN_SECONDS=120
