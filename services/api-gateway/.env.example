# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
DEMO_USERNAME=admin
DEMO_PASSWORD=demo-password
DEMO_ROLE=admin
# Optional automation credentials, comma-separated key:subject:role entries.
# Roles: admin, operator, viewer.
# MOIRA_API_KEYS=local-dev-key:local-automation:operator

# Redis
REDIS_URL=redis://redis:6379/0
RUN_TTL_SECONDS=604800

# Control plane
POSTGRES_DSN=postgresql://moiraweave:moiraweave-dev@postgres:5432/moiraweave
WORKLOADS_DIR=/workspace/workloads
ARTIFACTS_DIR=/workspace/artifacts

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=api-gateway
OTEL_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SAMPLE_RATE=1.0
